# Database
DATABASE_URL="postgresql://user:password@localhost:5432/formbuilder"

# Auth.js
AUTH_SECRET="your-secret-key-generate-with-openssl-rand-hex-32"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
