// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  forms              Form[]
  googleIntegrations GoogleIntegration[]
  responses          Response[]
  domainWhitelists   DomainWhitelist[]
  accounts           Account[]
  sessions           Session[]

  @@map("users")
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
  @@map("verification_tokens")
}

model Form {
  id          String  @id @default(cuid())
  title       String
  description String?
  slug        String  @unique @default(cuid())

  // Form structure stored as JSON
  fields Json[] // Array of field objects with conditional logic

  // Status and settings
  isPublished          Boolean @default(false)
  isAcceptingResponses Boolean @default(true)

  // Owner
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Google integration
  googleIntegrationId String?
  googleIntegration   GoogleIntegration? @relation(fields: [googleIntegrationId], references: [id], onDelete: SetNull)
  googleSheetId String? // For quick access without joining
  googleDriveFolderId String? // For quick access without joining

  // Publishing settings
  publishSettings Json? // Contains: redirectUrl, thankYouMessage, etc

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  responses Response[]

  @@index([userId])
  @@index([slug])
  @@map("forms")
}

model Response {
  id String @id @default(cuid())

  // Response data stored as JSON
  data Json // Object with field values

  // Form reference
  formId String
  form   Form   @relation(fields: [formId], references: [id], onDelete: Cascade)

  // User who submitted (optional)
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Sheet sync status
  syncedToSheet Boolean @default(false)
  sheetRowIndex Int?

  createdAt DateTime @default(now())

  @@index([formId])
  @@index([createdAt])
  @@map("responses")
}

model GoogleIntegration {
  id String @id @default(cuid())

  // Owner
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // OAuth tokens
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?

  // Spreadsheet config
  spreadsheetId   String?
  spreadsheetName String?
  sheetName       String? @default("Responses")

  // Drive config
  folderId   String?
  folderName String?

  // Status
  isConnected Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  forms Form[]

  @@unique([userId])
  @@map("google_integrations")
}

model DomainWhitelist {
  id String @id @default(cuid())

  domain String
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())

  @@unique([domain, userId])
  @@index([userId])
  @@map("domain_whitelists")
}
